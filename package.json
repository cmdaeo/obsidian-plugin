{
  "name": "obsidian-git-sync",
  "version": "1.0.1",
  "description": "Local-first Git synchronization for Obsidian using isomorphic-git.",
  "main": "release/main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json package.json"
  },
  "keywords": [
    "obsidian",
    "git",
    "sync"
  ],
  "author": "cmdaeo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "obsidian": "latest",
    "tslib": "2.6.0",
    "typescript": "5.3.3"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "isomorphic-git": "^1.27.0"
  }
}
